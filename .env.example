# Copy to .env and fill in your key
ANTHROPIC_API_KEY=sk-or-v1-your-key-here
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# Models (optional — defaults are in Dockerfile)
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5
ANTHROPIC_SMALL_FAST_MODEL=google/gemini-2.5-flash

# in case you want to use a free model for testing, you can set it here
ANTHROPIC_MODEL=openrouter/free
ANTHROPIC_SMALL_FAST_MODEL=openrouter/free
