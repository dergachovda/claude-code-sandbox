{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env-file", "${localWorkspaceFolder}/.env"
  ],
  // Named volume so Claude settings/sessions persist across container rebuilds.
  // To start fresh: docker volume rm claude-code-sandbox-claude-data
  "mounts": [
    "source=claude-code-sandbox-claude-data,target=/home/claude/.claude,type=volume"
  ],
  "remoteUser": "claude",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh" }
        }
      }
    }
  },
  "postCreateCommand": "echo '✅ Claude Code ready:' && claude --version"
}