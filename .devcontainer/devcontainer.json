{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env-file", "${localWorkspaceFolder}/.env"
  ],
  // Bind-mount ./data as the home dir — persists Claude config, settings, shell history, and
  // dotfiles as plain files in your repo folder (easy to inspect, backup, or wipe).
  // To start fresh: rm -rf ./data
  "mounts": [
    "source=${localWorkspaceFolder}/data,target=/home/claude,type=bind,consistency=cached"
  ],
  "remoteUser": "claude",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh" }
        }
      }
    }
  },
  // Seed home dir from the image on first create (bind-mount starts empty)
  "postCreateCommand": "([ -f ~/.zshrc ] || cp -a /opt/home-seed/. ~/) && echo '✅ Claude Code ready:' && claude --version"
}