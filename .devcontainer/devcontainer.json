{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env-file", "${localWorkspaceFolder}/.env"
  ],
  // Bind-mount ./workspace as the container's working directory.
  // Clone projects here and work on them with Claude Code.
  "workspaceMount": "source=${localWorkspaceFolder}/workspace,target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "remoteUser": "claude",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "/bin/bash" }
        }
      }
    }
  },
  "postCreateCommand": "echo '✅ Claude Code ready:' && claude --version"
}